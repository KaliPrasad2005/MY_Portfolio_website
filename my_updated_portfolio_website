<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kali Prasad A — 3D Portfolio</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --bg: #000008;
  --accent: #00ffff;
  --accent2: #ff00ff;
  --accent3: #ffff00;
  --text: #e0f0ff;
  --muted: #4a6080;
  --card-bg: rgba(0, 20, 40, 0.7);
}

html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Rajdhani', sans-serif;
  overflow-x: hidden;
  cursor: none;
}

/* Cursor */
#cursor {
  width: 8px; height: 8px;
  background: var(--accent);
  border-radius: 50%;
  position: fixed;
  pointer-events: none;
  z-index: 9999;
  transform: translate(-50%,-50%);
  box-shadow: 0 0 20px var(--accent), 0 0 40px var(--accent);
  transition: width 0.2s, height 0.2s;
}
#cursor-trail {
  width: 30px; height: 30px;
  border: 1px solid rgba(0,255,255,0.4);
  border-radius: 50%;
  position: fixed;
  pointer-events: none;
  z-index: 9998;
  transform: translate(-50%,-50%);
  transition: all 0.08s linear;
}

/* Canvas */
#three-canvas {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  pointer-events: none;
}

/* Nav */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  padding: 1.5rem 3rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(0,255,255,0.1);
}

.nav-logo {
  font-family: 'Orbitron', monospace;
  font-weight: 900;
  font-size: 1.1rem;
  color: var(--accent);
  text-shadow: 0 0 20px var(--accent);
  letter-spacing: 0.1em;
}

.nav-links {
  display: flex;
  gap: 2rem;
  list-style: none;
}

.nav-links a {
  font-family: 'Share Tech Mono', monospace;
  font-size: 0.75rem;
  color: var(--muted);
  text-decoration: none;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  transition: color 0.3s, text-shadow 0.3s;
  position: relative;
}
.nav-links a::after {
  content: '';
  position: absolute;
  bottom: -4px; left: 0; right: 0;
  height: 1px;
  background: var(--accent);
  transform: scaleX(0);
  transition: transform 0.3s;
}
.nav-links a:hover { color: var(--accent); text-shadow: 0 0 10px var(--accent); }
.nav-links a:hover::after { transform: scaleX(1); }

/* Sections */
section {
  position: relative;
  z-index: 10;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 8rem 5rem 4rem;
}

/* Hero */
#hero {
  align-items: flex-start;
  padding-top: 10rem;
}

.hero-sub {
  font-family: 'Share Tech Mono', monospace;
  font-size: 0.75rem;
  letter-spacing: 0.3em;
  color: var(--accent);
  text-transform: uppercase;
  margin-bottom: 1.5rem;
  opacity: 0;
  animation: fadeUp 1s 0.3s ease forwards;
}

.hero-name {
  font-family: 'Orbitron', monospace;
  font-weight: 900;
  font-size: clamp(3rem, 8vw, 8rem);
  line-height: 0.9;
  letter-spacing: -0.02em;
  margin-bottom: 1rem;
  opacity: 0;
  animation: fadeUp 1s 0.5s ease forwards;
}

.hero-name .line1 { display: block; color: var(--text); }
.hero-name .line2 {
  display: block;
  background: linear-gradient(90deg, var(--accent), var(--accent2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-title {
  font-family: 'Rajdhani', sans-serif;
  font-size: 1.4rem;
  font-weight: 300;
  color: var(--muted);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 2.5rem;
  opacity: 0;
  animation: fadeUp 1s 0.7s ease forwards;
}

.hero-title span { color: var(--accent2); }

.hero-actions {
  display: flex;
  gap: 1.2rem;
  opacity: 0;
  animation: fadeUp 1s 0.9s ease forwards;
  flex-wrap: wrap;
}

.btn-3d {
  position: relative;
  padding: 0.9rem 2.2rem;
  font-family: 'Share Tech Mono', monospace;
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  text-decoration: none;
  border: none;
  cursor: none;
  transition: all 0.3s;
  overflow: hidden;
}

.btn-3d-primary {
  background: var(--accent);
  color: #000;
  box-shadow: 0 0 30px rgba(0,255,255,0.5), inset 0 0 30px rgba(255,255,255,0.1);
}
.btn-3d-primary:hover {
  box-shadow: 0 0 60px rgba(0,255,255,0.8), inset 0 0 30px rgba(255,255,255,0.2);
  transform: translateY(-3px) scale(1.02);
}

.btn-3d-outline {
  background: transparent;
  color: var(--accent);
  border: 1px solid var(--accent);
  box-shadow: 0 0 15px rgba(0,255,255,0.2), inset 0 0 15px rgba(0,255,255,0.05);
}
.btn-3d-outline:hover {
  background: rgba(0,255,255,0.1);
  box-shadow: 0 0 30px rgba(0,255,255,0.4);
  transform: translateY(-3px);
}

/* Glitch text effect */
.glitch {
  position: relative;
}
.glitch::before, .glitch::after {
  content: attr(data-text);
  position: absolute;
  top: 0; left: 0;
  width: 100%;
}
.glitch::before {
  color: var(--accent2);
  animation: glitch1 3s infinite;
  clip-path: polygon(0 0, 100% 0, 100% 45%, 0 45%);
}
.glitch::after {
  color: var(--accent);
  animation: glitch2 3s infinite;
  clip-path: polygon(0 55%, 100% 55%, 100% 100%, 0 100%);
}

@keyframes glitch1 {
  0%, 90%, 100% { transform: translate(0); opacity: 0; }
  92% { transform: translate(-3px, 1px); opacity: 0.8; }
  94% { transform: translate(3px, -1px); opacity: 0.8; }
  96% { transform: translate(0); opacity: 0; }
}
@keyframes glitch2 {
  0%, 90%, 100% { transform: translate(0); opacity: 0; }
  93% { transform: translate(3px, 2px); opacity: 0.8; }
  95% { transform: translate(-3px, -1px); opacity: 0.8; }
  97% { transform: translate(0); opacity: 0; }
}

/* Section headers */
.section-tag {
  font-family: 'Share Tech Mono', monospace;
  font-size: 0.7rem;
  color: var(--accent);
  letter-spacing: 0.3em;
  text-transform: uppercase;
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: 1rem;
}
.section-tag::before {
  content: '';
  width: 40px; height: 1px;
  background: var(--accent);
  box-shadow: 0 0 10px var(--accent);
}

.section-title {
  font-family: 'Orbitron', monospace;
  font-weight: 900;
  font-size: clamp(2rem, 4vw, 3.5rem);
  letter-spacing: -0.02em;
  margin-bottom: 3rem;
  line-height: 1.1;
}

/* About */
#about { background: rgba(0,0,8,0.5); }

.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: start;
}

.about-text p {
  font-size: 1.1rem;
  color: rgba(224,240,255,0.7);
  line-height: 1.9;
  margin-bottom: 1.5rem;
  font-weight: 300;
}

/* 3D Card */
.card-3d {
  background: var(--card-bg);
  border: 1px solid rgba(0,255,255,0.15);
  padding: 2rem;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.3s, box-shadow 0.3s;
  backdrop-filter: blur(10px);
}
.card-3d:hover {
  box-shadow: 0 20px 60px rgba(0,255,255,0.2), 0 0 0 1px rgba(0,255,255,0.3);
}
.card-3d::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(0,255,255,0.05) 0%, transparent 50%, rgba(255,0,255,0.05) 100%);
  pointer-events: none;
}

/* Terminal */
.terminal {
  background: rgba(0,5,15,0.9);
  border: 1px solid rgba(0,255,255,0.2);
  font-family: 'Share Tech Mono', monospace;
  font-size: 0.8rem;
  overflow: hidden;
}
.terminal-header {
  background: rgba(0,255,255,0.05);
  padding: 0.7rem 1rem;
  border-bottom: 1px solid rgba(0,255,255,0.15);
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.t-dot { width: 10px; height: 10px; border-radius: 50%; }
.t-dot:nth-child(1) { background: #ff5f57; box-shadow: 0 0 6px #ff5f57; }
.t-dot:nth-child(2) { background: #febc2e; box-shadow: 0 0 6px #febc2e; }
.t-dot:nth-child(3) { background: #28c840; box-shadow: 0 0 6px #28c840; }
.t-title { color: rgba(0,255,255,0.5); font-size: 0.65rem; letter-spacing: 0.1em; margin: 0 auto; }
.terminal-body { padding: 1.5rem; line-height: 2.2; }
.t-line { display: flex; gap: 0.8rem; }
.t-prompt { color: #28c840; }
.t-cmd { color: var(--text); }
.t-out { padding-left: 1.5rem; }
.t-key { color: var(--accent3); }
.t-val { color: #a5f3fc; }
.t-str { color: #86efac; }
.t-cursor { display: inline-block; width: 8px; height: 1em; background: var(--accent); animation: blink 1s infinite; vertical-align: text-bottom; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

/* Skills */
#skills { background: rgba(0,0,20,0.6); }

.skills-3d-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.skill-3d-card {
  background: var(--card-bg);
  border: 1px solid rgba(0,255,255,0.1);
  padding: 2rem 1.5rem;
  position: relative;
  overflow: hidden;
  cursor: none;
  transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
  transform-style: preserve-3d;
}

.skill-3d-card::before {
  content: '';
  position: absolute;
  top: -50%; left: -50%;
  width: 200%; height: 200%;
  background: conic-gradient(from 0deg, transparent 0deg, rgba(0,255,255,0.05) 60deg, transparent 120deg);
  animation: rotateBg 4s linear infinite;
  opacity: 0;
  transition: opacity 0.3s;
}
.skill-3d-card:hover::before { opacity: 1; }

.skill-3d-card::after {
  content: '';
  position: absolute;
  inset: 1px;
  background: rgba(0,5,20,0.9);
  z-index: 0;
}

.skill-card-inner { position: relative; z-index: 1; }

@keyframes rotateBg {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.skill-3d-card:hover {
  transform: translateY(-8px) rotateX(5deg);
  border-color: var(--accent);
  box-shadow: 0 30px 60px rgba(0,255,255,0.2), 0 0 0 1px rgba(0,255,255,0.3);
}

.skill-icon-3d {
  font-size: 2.5rem;
  margin-bottom: 1rem;
  filter: drop-shadow(0 0 10px rgba(0,255,255,0.5));
}

.skill-name {
  font-family: 'Orbitron', monospace;
  font-weight: 700;
  font-size: 0.85rem;
  color: var(--accent);
  letter-spacing: 0.05em;
  margin-bottom: 0.7rem;
}

.skill-desc {
  font-size: 0.85rem;
  color: var(--muted);
  line-height: 1.6;
  margin-bottom: 1rem;
}

.skill-tags-3d {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.stag {
  padding: 0.2rem 0.6rem;
  font-family: 'Share Tech Mono', monospace;
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  border: 1px solid rgba(0,255,255,0.3);
  color: var(--accent);
  text-transform: uppercase;
}

/* Experience */
#experience { background: rgba(0,0,8,0.5); }

.exp-3d {
  position: relative;
  padding: 3rem;
  background: var(--card-bg);
  border: 1px solid rgba(0,255,255,0.15);
  backdrop-filter: blur(10px);
  overflow: hidden;
}

.exp-3d::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  background: linear-gradient(to bottom, var(--accent), var(--accent2));
  box-shadow: 0 0 20px var(--accent);
}

.exp-corner {
  position: absolute;
  width: 20px; height: 20px;
}
.exp-corner-tl { top: 0; left: 0; border-top: 2px solid var(--accent); border-left: 2px solid var(--accent); }
.exp-corner-tr { top: 0; right: 0; border-top: 2px solid var(--accent); border-right: 2px solid var(--accent); }
.exp-corner-bl { bottom: 0; left: 0; border-bottom: 2px solid var(--accent); border-left: 2px solid var(--accent); }
.exp-corner-br { bottom: 0; right: 0; border-bottom: 2px solid var(--accent); border-right: 2px solid var(--accent); }

.exp-badge-3d {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.4rem 1rem;
  background: rgba(0,255,255,0.1);
  border: 1px solid var(--accent);
  font-family: 'Share Tech Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  color: var(--accent);
  text-transform: uppercase;
  margin-bottom: 1.5rem;
  box-shadow: 0 0 20px rgba(0,255,255,0.2);
}

.live-dot {
  width: 6px; height: 6px;
  background: #00ff88;
  border-radius: 50%;
  box-shadow: 0 0 10px #00ff88;
  animation: pulse 2s infinite;
}

.exp-company {
  font-family: 'Orbitron', monospace;
  font-weight: 900;
  font-size: 2rem;
  color: var(--accent);
  text-shadow: 0 0 30px rgba(0,255,255,0.5);
  margin-bottom: 0.5rem;
}

.exp-role-3d {
  font-family: 'Rajdhani', sans-serif;
  font-size: 1.3rem;
  font-weight: 600;
  color: var(--text);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 1.5rem;
}

.exp-desc-3d {
  font-size: 1.05rem;
  color: rgba(224,240,255,0.65);
  line-height: 1.8;
  max-width: 600px;
}

/* Education */
#education { background: rgba(0,0,20,0.6); }

.edu-3d-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
}

.edu-3d-card {
  background: var(--card-bg);
  border: 1px solid rgba(255,0,255,0.15);
  padding: 2.5rem;
  position: relative;
  overflow: hidden;
  transition: all 0.4s;
  cursor: none;
}

.edu-3d-card::before {
  content: attr(data-year);
  position: absolute;
  right: -1rem; bottom: -1rem;
  font-family: 'Orbitron', monospace;
  font-size: 6rem;
  font-weight: 900;
  color: rgba(255,0,255,0.04);
  line-height: 1;
  pointer-events: none;
}

.edu-3d-card:hover {
  border-color: var(--accent2);
  box-shadow: 0 20px 60px rgba(255,0,255,0.15), 0 0 0 1px rgba(255,0,255,0.2);
  transform: translateY(-6px);
}

.edu-type {
  font-family: 'Share Tech Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  color: var(--accent2);
  text-transform: uppercase;
  margin-bottom: 1rem;
  text-shadow: 0 0 10px var(--accent2);
}

.edu-school-3d {
  font-family: 'Orbitron', monospace;
  font-weight: 700;
  font-size: 1rem;
  color: var(--text);
  margin-bottom: 0.5rem;
  line-height: 1.3;
}

.edu-field-3d {
  font-size: 0.9rem;
  color: var(--muted);
  margin-bottom: 1rem;
}

.edu-period-3d {
  font-family: 'Share Tech Mono', monospace;
  font-size: 0.7rem;
  color: rgba(0,255,255,0.5);
  letter-spacing: 0.08em;
}

/* Certifications */
#certifications { background: rgba(0,0,8,0.5); }

.certs-3d-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}

.cert-3d-card {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  padding: 1.8rem;
  background: var(--card-bg);
  border: 1px solid rgba(255,255,0,0.1);
  position: relative;
  overflow: hidden;
  transition: all 0.4s;
  cursor: none;
}

.cert-3d-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(255,255,0,0.03) 0%, transparent 100%);
  opacity: 0;
  transition: opacity 0.3s;
}
.cert-3d-card:hover::before { opacity: 1; }

.cert-3d-card:hover {
  border-color: var(--accent3);
  box-shadow: 0 10px 40px rgba(255,255,0,0.1), 0 0 0 1px rgba(255,255,0,0.2);
  transform: translateX(6px);
}

.cert-hex {
  width: 55px; height: 55px;
  background: linear-gradient(135deg, var(--accent3), #f97316);
  clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.4rem;
  flex-shrink: 0;
  box-shadow: 0 0 20px rgba(255,255,0,0.4);
}

.cert-name-3d {
  font-family: 'Rajdhani', sans-serif;
  font-weight: 600;
  font-size: 0.95rem;
  letter-spacing: 0.05em;
  color: var(--text);
  margin-bottom: 0.3rem;
}

.cert-issuer-3d {
  font-family: 'Share Tech Mono', monospace;
  font-size: 0.65rem;
  color: var(--accent3);
  letter-spacing: 0.1em;
}

/* Contact */
#contact { background: rgba(0,0,20,0.6); }

.contact-3d-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: start;
}

.contact-tagline {
  font-family: 'Orbitron', monospace;
  font-size: clamp(1.5rem, 3vw, 2.5rem);
  font-weight: 900;
  line-height: 1.2;
  margin-bottom: 1.5rem;
}
.contact-tagline span { color: var(--accent); text-shadow: 0 0 20px var(--accent); }

.contact-sub {
  font-size: 1.05rem;
  color: var(--muted);
  line-height: 1.7;
  margin-bottom: 2rem;
}

.contact-links-3d {
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
}

.contact-link-3d {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 1.5rem;
  background: var(--card-bg);
  border: 1px solid rgba(0,255,255,0.1);
  text-decoration: none;
  color: var(--text);
  font-family: 'Share Tech Mono', monospace;
  font-size: 0.75rem;
  letter-spacing: 0.05em;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.contact-link-3d::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 0;
  background: rgba(0,255,255,0.08);
  transition: width 0.3s;
}
.contact-link-3d:hover::before { width: 100%; }
.contact-link-3d:hover {
  border-color: var(--accent);
  color: var(--accent);
  transform: translateX(8px);
  box-shadow: 0 0 20px rgba(0,255,255,0.15);
}

.cl-icon { font-size: 1.1rem; flex-shrink: 0; }

.contact-form-3d {
  background: var(--card-bg);
  border: 1px solid rgba(0,255,255,0.15);
  padding: 2.5rem;
  backdrop-filter: blur(10px);
  position: relative;
}

.contact-form-3d::before,
.contact-form-3d::after {
  content: '';
  position: absolute;
  width: 20px; height: 20px;
}
.contact-form-3d::before { top: 0; left: 0; border-top: 2px solid var(--accent); border-left: 2px solid var(--accent); }
.contact-form-3d::after { bottom: 0; right: 0; border-bottom: 2px solid var(--accent); border-right: 2px solid var(--accent); }

.form-title-3d {
  font-family: 'Orbitron', monospace;
  font-weight: 700;
  font-size: 1rem;
  color: var(--accent);
  margin-bottom: 2rem;
  letter-spacing: 0.05em;
}

.fg { margin-bottom: 1.3rem; }

.fl {
  display: block;
  font-family: 'Share Tech Mono', monospace;
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 0.5rem;
}

.fi, .fta {
  width: 100%;
  background: rgba(0,10,30,0.8);
  border: 1px solid rgba(0,255,255,0.15);
  color: var(--text);
  padding: 0.8rem 1rem;
  font-family: 'Share Tech Mono', monospace;
  font-size: 0.8rem;
  outline: none;
  transition: border-color 0.3s, box-shadow 0.3s;
  resize: none;
}
.fi:focus, .fta:focus {
  border-color: var(--accent);
  box-shadow: 0 0 15px rgba(0,255,255,0.2);
